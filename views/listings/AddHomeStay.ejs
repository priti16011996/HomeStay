<% layout("/layouts/boilerplate.ejs")  %>
<div class="add-listing-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="form-card">

                    <h2 class="text-center form-title mb-4">🏡 Add Your Homestay</h2>

                    <form method="POST" action="/Listings?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">

                        <!-- Title -->
                        <div class="mb-3">
                            <label class="form-label">Homestay Name</label>
                            <input type="text" name="listing[title]" class="form-control" placeholder="Enter homestay name" required>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="listing[description]" class="form-control" rows="3" placeholder="Describe your homestay..." required></textarea>
                        </div>

                        <!-- Location -->
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" name="listing[location]" class="form-control" placeholder="City / Area" required>
                        </div>

                        <!-- Price + Country -->
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Price (₹)</label>
                                <input type="number" name="listing[price]" class="form-control" required>
                            </div>

                            <div class="col-md-8 mb-3">
                                <label class="form-label">Country</label>
                                <input type="text" name="listing[country]" class="form-control" required>
                            </div>
                        </div>

                        <!-- Image Upload -->
                        <div class="mb-3">
                            <label class="form-label">Upload Image</label>
                            <input type="file" name="listing[image]" id="imageInput" class="form-control" accept="image/*" required>
                            <img id="preview" class="image-preview" />
                        </div>

                        <button class="btn btn-add w-100 mt-3">Add Homestay</button>

                    </form>

                </div>

            </div>
        </div>
    </div>
</div>
<script>
    const imageInput = document.getElementById("imageInput");
    const preview = document.getElementById("preview");

    imageInput.addEventListener("change", function () {
        const file = this.files[0];
        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.style.display = "block";
        }
    });
</script>