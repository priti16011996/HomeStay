<!-- HERO SECTION -->
<section class="hero d-flex align-items-center">
  <div class="container">
    <div class="row">
      <div class="col-lg-6 text-dark">
        <h1 class="fw-bold display-4">Belong anywhere</h1>
        <p class="lead">Find and book unique places to stay around the world.</p>

        <!-- SEARCH BOX -->
        <div class="search-box p-3 mt-4">
          <div class="row g-2 align-items-center">

            <div class="col-md-3">
              <label class="form-label small">Where</label>
              <input type="text" class="form-control" placeholder="Search destinations">
            </div>

            <div class="col-md-2">
              <label class="form-label small">Check in</label>
              <input type="date" class="form-control">
            </div>

            <div class="col-md-2">
              <label class="form-label small">Check out</label>
              <input type="date" class="form-control">
            </div>

            <div class="col-md-2">
              <label class="form-label small">Guests</label>
              <input type="number" class="form-control" placeholder="Add guests">
            </div>

            <div class="col-md-3">
              <button class="btn btn-danger w-100 mt-3 mt-md-0">
                <i class="bi bi-search"></i> Explore
              </button>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHY SECTION -->
<section class="why py-5 text-center">
  <div class="container">
    <h2 class="mb-5 fw-bold">Why HotelsHub?</h2>

    <div class="row g-4">

      <div class="col-md-3">
        <i class="bi bi-house icon"></i>
        <h5 class="mt-3">Unique stays</h5>
        <p>Stay in homes, cabins, castles, and more. Anything but ordinary.</p>
      </div>

      <div class="col-md-3">
        <i class="bi bi-tag icon"></i>
        <h5 class="mt-3">Great prices</h5>
        <p>Find stays that fit your budget without compromising comfort.</p>
      </div>

      <div class="col-md-3">
        <i class="bi bi-globe icon"></i>
        <h5 class="mt-3">Global access</h5>
        <p>Explore millions of places in 220+ countries and regions.</p>
      </div>

      <div class="col-md-3">
        <i class="bi bi-shield-check icon"></i>
        <h5 class="mt-3">Trusted and safe</h5>
        <p>24/7 support and verified reviews for peace of mind.</p>
      </div>

    </div>
  </div>
</section>
