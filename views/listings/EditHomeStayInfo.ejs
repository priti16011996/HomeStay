<% layout("/layouts/boilerplate.ejs") %>

    <body>
        <div class="row">
            <div class="col-8 offset-2 mt-3">
                <h2>To Edit Home Stay Enter Details:</h2>
                <form method="POST" action="/Listings/<%= HomeStayData._id %>?_method=PUT">
                    <div class="mb-3">
                        <label for="title" class="form-label">Name:</label>
                        <input type="text" name="listing[title]" value="<%= HomeStayData.title %>" id="title"
                            class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Decription:</label>
                        <textarea name="listing[description]" id="description" class="form-control">
                            <%= HomeStayData.description %></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="location" class="form-label">Location:</label>
                        <input type="text" name="listing[location]" value="<%= HomeStayData.location %>" id="location"
                            class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="price" class="form-label">Price:</label>
                            <input type="text" name="listing[price]" value="<%= HomeStayData.price %>" id="price"
                                class="form-control" />
                        </div>
                        <div class="col-md-8 mb-3">
                            <label for="country" class="form-label">Country:</label>
                            <input type="text" name="listing[country]" value="<%= HomeStayData.country %>" id="country"
                                class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Image URL:</label>
                        <input type="text" name="listing[image]" value="<%= HomeStayData.image.url %>" id="image"
                            class="form-control" />
                    </div>

                    <button class="btn btn-dark edit-btn mt-3">Edit</button>
                </form>
            </div>
        </div>
    </body>