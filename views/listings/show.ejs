<% layout("/layouts/boilerplate.ejs")  %>
  <body>
    <div class="row mt-2">
      <div class="col-8 offset-2">
          <h2><i><%= specificHomeStayData.title %></h2><br>
      </div>
      <div class="col-6 offset-2 fs-6">
        <div class="card listing-card" >
          <img src="<%= specificHomeStayData.image.url %>" class="card-img-top show-img" alt="ListingItem Image">
          <div class="card-body">
            <p class="card-text">
              <b>Property is listed By@</b><i><%= specificHomeStayData.owner[0].username %></i><br/>
              <%= specificHomeStayData.description %><br/>
              <span style="color:green;">₹<%= specificHomeStayData.price.toLocaleString("en-IN") %> </span><br/>
              <%= specificHomeStayData.location %><br/>
              <%= specificHomeStayData.country %>
            </p>
           
            <% if (
                  currentUser &&
                  specificHomeStayData.owner &&
                  specificHomeStayData.owner[0]._id.toString() === currentUser._id.toString()
                ) { %>
            <!-- ✅ Buttons aligned properly -->
            <div class="d-flex gap-2 mt-3">
              <form method="POST" action="/Listings/<%= specificHomeStayData._id %>/editHomeStayDesc">
                <button type="submit" class="btn btn-primary">Edit</button>
              </form>

              <form method="POST" action="/Listings/<%= specificHomeStayData._id %>?_method=DELETE">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
            <% } %>
            <div>
              <hr>
              <% if(currentUser){ %>
              <h3>Write your valuable feedback</h3>
              <form method="POST" action="/listings/<%= specificHomeStayData._id %>/reviews" novalidate class="needs-validation">
                <label for="no-rate">Rating</label>
                <fieldset class="starability-slot">
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="review[rating]" id="rating" value="1" />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="review[rating]" id="rating"  value="2" />
                  <label for="first-rate2" title="Not good">2 stars</label>
                  <input type="radio" id="first-rate3" name="review[rating]" id="rating"  value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="review[rating]" id="rating" value="4" />
                  <label for="first-rate4" title="Very good">4 stars</label>
                  <input type="radio" id="first-rate5" name="review[rating]" id="rating" value="5" />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                <label for="comment">Comment</label><br>  
                <textarea id="comment" name="review[comment]" rows="5" cols="50" required></textarea>
                <br>
                <div class="invalid-feedback">Please add your valuable feedback</div>
                <br>
                <button type="submit" class="btn btn-success">Submit</button>
              </form>
              <hr> 
              <% } %>   
              
              <p><b>All Reviews:</b></p>
              <div class="row">
                  <% specificHomeStayData.reviews.forEach(review => { %>
                <div class="card col-5 ms-3 mb-3">
                  <h5 class="card-title">@<%= review.author.username %></h5>
                  <div class="card-body">
                    <p class="starability-result card-text" data-rating="<%= review.rating %>">
                      <%= review.rating %>
                    </p><br>
                    <p class="card-text"><strong>Comment:</strong> <%= review.comment %></p>
                    <form class=""mb-3 method="POST" action="/listings/<%= specificHomeStayData._id %>/reviews/<%= review._id %>?_method=DELETE"><br>
                    <button class="btn btn-sm btn-danger mb-3" >Delete</button><br>
                  </form>
                  </div>
                </div>
              <% }) %>
              </div>
              
            
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </body>