<% layout("/layouts/boilerplate.ejs")  %>
  <body>
    <div class="row mt-2">
      <div class="col-8 offset-2">
          <h2><i><%= specificHomeStayData.title %></h2><br>
      </div>
      <div class="col-6 offset-2 fs-6">
        <div class="card" >
          <img src="<%= specificHomeStayData.image.url %>" class="card-img-top show-img" alt="ListingItem Image">
          <div class="card-body">
            <p class="card-text">
              <%= specificHomeStayData.description %><br/>
              <span style="color:green;">₹<%= specificHomeStayData.price.toLocaleString("en-IN") %> </span><br/>
              <%= specificHomeStayData.location %><br/>
              <%= specificHomeStayData.country %>
            </p>
            <!-- ✅ Buttons aligned properly -->
            <div class="d-flex gap-2 mt-3">
              <form method="POST" action="/Listings/<%= specificHomeStayData._id %>/editHomeStayDesc">
                <button type="submit" class="btn btn-primary">Edit</button>
              </form>

              <form method="POST" action="/Listings/<%= specificHomeStayData._id %>?_method=DELETE">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
            <div>
              <hr>
              <h3>Write your valuable feedback</h3>
              <form method="POST" action="/listings/<%= specificHomeStayData._id %>/reviews">
                <label for="rating">Rating</label>
                <input type="range" id="rating" name="review[rating]" min="1" max="5"><br><br>
                <label for="comment">Comment</label><br>  
                <textarea id="comment" name="review[comment]" rows="5" cols="50"></textarea><br><br>
                <button type="submit" class="btn btn-primary">Submit</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </body>